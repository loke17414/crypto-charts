# Binance Futures API
# Testnet keys: https://testnet.binancefuture.com/
# Live keys:   https://www.binance.com/en/my/settings/api-management
# Web UI "테스트넷 연결" also saves keys here — survives browser close & server restart.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Phase 2-A: multi-user auth ---
# Local/dev default: SQLite (auto file at data/cryptocharts.db)
# Production (required before growth): PostgreSQL
#   sudo bash deploy/setup-postgres.sh
#   # or full baseline: sudo bash deploy/bootstrap-production.sh --origin https://orbinex.net
# DATABASE_URL=postgresql://orbinex:PASSWORD@127.0.0.1:5432/orbinex
AUTH_REQUIRED=true
# Comma-separated admin emails for admin console (/admin-site/ or admin.<domain>)
# and /api/admin/*
ADMIN_EMAILS=
# Required when AUTH_REQUIRED=true. Must stay stable across restarts
# (empty → auto-generated once and saved). Changing it logs everyone out.
JWT_SECRET=
JWT_ALGORITHM=HS256
# Production: 10080 = 7d. 0 = never expire (dev only).
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Customer support + optional KR business identity (legal/footer)
SUPPORT_EMAIL=support@orbinex.net
# BUSINESS_NAME=
# BUSINESS_REPRESENTATIVE=
# BUSINESS_REGISTRATION_NUMBER=
# BUSINESS_ADDRESS=
# Phase 2-B — encrypt per-user Binance keys.
# Auto-generated on first per-user connect if empty. Keep stable across restarts.
# Or generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

# --- Phase 2-E: HTTPS + CORS (public launch) ---
# After: sudo bash deploy/setup-https.sh orbinex.net you@email.com
# Comma-separated if admin subdomain is enabled:
# APP_ORIGIN=https://orbinex.net,https://admin.orbinex.net
APP_ORIGIN=https://orbinex.net
# Behind nginx: bind app to localhost only (setup-https.sh sets this).
# LISTEN_HOST=127.0.0.1
# Optional standalone console: sudo bash deploy/setup-admin-subdomain.sh orbinex.net you@email.com

# Ops: Discord/Slack webhook for deploy/monitor.sh alerts (optional)
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# MONITOR_DISK_MIN_PCT_FREE=10

# Signup rate limit — max registrations per IP within the window (default 5/hour).
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW_SECONDS=3600

# Concurrent Node bots (raise only after VPS RAM allows)
MAX_CONCURRENT_BOTS=50
BILLING_ENFORCE=true

# --- Email (인증 / 비밀번호 재설정) ---
# 운영 권장: Resend API만 사용. SMTP_* / SMTP2_* 는 전부 주석 처리하세요.
# (SMTP가 남아 있으면 Resend 실패 후 Gmail/네이버 535로 폴백되어 가입이 막힙니다.)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Orbinex <auth@orbinex.net>   # noreply 보다 수신함 (스팸 감소)
# # RESEND_REPLY_TO=support@orbinex.net
# EMAIL_REQUIRE_VERIFICATION=true
# APP_ORIGIN=https://orbinex.net
# # Resend 실패 시 SMTP 폴백 (비권장): MAIL_FALLBACK_SMTP=true
#
# 로컬/임시 — Gmail SMTP만:
# SMTP_PROVIDER=gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=十六자리앱비밀번호공백없이
# SMTP_FROM=you@gmail.com
# SMTP_USE_TLS=true
# ※ 일반 Gmail 비밀번호 아님. https://myaccount.google.com/apppasswords 에서 발급.

# Phase 2-C — one Node bot process per logged-in user (data/bots/{user_id}/).
# MAX_CONCURRENT_BOTS is set above (production baseline).
# Binance IP whitelist hint — VPS public outbound IP (users must add this in Binance API settings).
# PLATFORM_OUTBOUND_IP=158.247.204.60
# Commercial: do NOT also run deploy/crypto-bot.service or docker crypto-bot —
# those are single-tenant and share files with the web-managed bots.

# true = futures testnet, false = real trading
BINANCE_TESTNET=true

# true = simulate orders without API calls
DRY_RUN=true

# Trading pair and candle interval
SYMBOL=BTCUSDT
INTERVAL=1h

# Futures leverage & margin
LEVERAGE=5
MARGIN_TYPE=ISOLATED

# Allow short positions (true recommended for futures)
ALLOW_SHORT=true

# Strategy: EMA crossover + RSI
RSI_PERIOD=14
RSI_OVERSOLD=25
RSI_OVERBOUGHT=70

# RSI entry filter (only enter when RSI meets minimum)
USE_RSI_ENTRY_FILTER=false
# Long: enter only when RSI >= this value (leave empty to disable)
RSI_LONG_MIN=
# Short: enter only when RSI <= this value (leave empty to disable)
RSI_SHORT_MAX=

EMA_FAST=12
EMA_SLOW=26

# MACD filter (12, 26, 9)
USE_MACD=true
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# MACD line value filter (only enter when MACD line meets threshold)
USE_MACD_LINE_FILTER=false
# Long: enter only when MACD line >= this value (leave empty to disable)
MACD_LONG_MIN=
# Short: enter only when MACD line <= this value (leave empty to disable)
MACD_SHORT_MAX=

# Swing high/low filter (pivot levels for long/short)
USE_SWING_LEVELS=false
SWING_PIVOT_BARS=5
SWING_LOOKBACK=50
SWING_NEAR_PCT=0.5
# bounce = long near swing low / short near swing high
# breakout = long above swing high / short below swing low
SWING_MODE=bounce

# Swing-based stop loss (long: below swing low, short: above swing high)
USE_SWING_STOP_LOSS=false
SWING_STOP_BUFFER_PCT=0.2

# Risk management — price move % from entry (ROE ≈ move × leverage)
STOP_LOSS_PCT=1.5
TAKE_PROFIT_PCT=3.0

# Risk-based position sizing (max loss as % of equity at stop-loss)
RISK_PER_TRADE_PCT=1.0
# Stop bot if total drawdown from session start exceeds this %
MAX_ACCOUNT_LOSS_PCT=5.0

# How often to check for signals (seconds)
POLL_SECONDS=60

# --- Billing (토스페이먼츠 자동결제/빌링키 — 한국) ---
# Stripe는 한국 사업자 일반 사용이 어려워 Toss Payments를 사용합니다.
# 1) https://developers.tosspayments.com 가입 → API 키 (자동결제 MID)
# 2) 자동결제(빌링) 추가 계약 필요 (테스트 키로 연동 가능)
# 3) APP_ORIGIN=https://orbinex.net 설정 (Toss success/fail → billing.html)
# TOSS_CLIENT_KEY=test_ck_...
# TOSS_SECRET_KEY=test_sk_...
# TOSS_PRO_AMOUNT_KRW=29000
# TOSS_PRO_ORDER_NAME=Orbinex Pro Monthly
# GPT add-on pack (Pro only, billing-key one-shot charge)
# GPT_PACK_AMOUNT_KRW=5000
# GPT_PACK_CALLS=50
# GPT_PACK_ORDER_NAME=Orbinex GPT Pack
# Enforce free quotas (bot hours / GPT). Default = same as AUTH_REQUIRED.
# BILLING_ENFORCE=true
# Free / Pro weekly GPT limits
FREE_BOT_HOURS_PER_WEEK=48
FREE_GPT_CALLS_PER_WEEK=10
PRO_GPT_CALLS_PER_WEEK=100
# Free: single entry-condition slot (multi-slot = Pro)
FREE_MAX_STRATEGY_SLOTS=1
PRO_MAX_STRATEGY_SLOTS=6
# Free web strategy research (default off — Pro feature)
# FREE_WEB_RESEARCH=false
# Free AI recommended strategies (default off — Pro feature)
# FREE_RECOMMENDED_STRATEGIES=false
# Week reset timezone (Monday 00:00)
BILLING_WEEK_TIMEZONE=Asia/Seoul

# OpenAI — PLATFORM HOSTED (all logged-in users share this key for GPT strategy AI).
# Set on the VPS .env. End users do NOT enter keys in the UI when AUTH_REQUIRED=true.
OPENAI_API_KEY=
# Default model for simple tasks (questions, SL/TP-only edits)
OPENAI_MODEL=gpt-4o-mini
# Model for hard tasks (entry rules, indicators, multi-slot strategy)
OPENAI_MODEL_COMPLEX=gpt-4o
# hybrid = auto-route by prompt; off/single = always OPENAI_MODEL; complex/all = always OPENAI_MODEL_COMPLEX
OPENAI_MODEL_ROUTING=hybrid
# Cache successful key checks (seconds). Avoids a paid chat test on every page load / message.
# OPENAI_VERIFY_CACHE_SECONDS=21600

# --- 24/7 headless bot (bot-js/bot.js — identical to the trading UI) ---
# OR remote web UI on VPS (Method 2):
#   LISTEN_HOST=0.0.0.0 ./deploy/deploy-web.sh
#   Firewall: TCP 8765 (web) + 8000 (API). Do NOT run docker crypto-bot and web bot together.
# LISTEN_HOST=127.0.0.1
# Runs the SAME strategy engine as the web UI, no browser needed. Deploy on a
# VPS with Docker or systemd (see Dockerfile / deploy/crypto-bot.service).
#   1) DRY_RUN=false + testnet API keys above for real testnet trading
#   2) Export your strategy from the UI ("전략 내보내기 (서버용)") -> strategy.json
#      in the project root. strategy.json overrides SYMBOL/LEVERAGE/risk/etc.
#   3) Optional: STRATEGY_FILE=/abs/path/to/strategy.json
# STRATEGY_FILE=
# DRY_CASH=10000   # starting balance for DRY_RUN simulation
